set shell := ["bash", "-cu"]
set dotenv-load := true

COMPOSE := "docker compose -f docker-compose.yml"

# List available recipes
default:
    @just --list

# Build the container image
build:
    {{ COMPOSE }} build

# Start remote-control server (requires prior `just login`)
up:
    {{ COMPOSE }} up

# Build and start in one step
start: build up

# One-time OAuth login for Max subscription — paste the printed URL in your browser
login:
    {{ COMPOSE }} run --rm claude claude login

# Open an interactive shell inside the container
shell:
    {{ COMPOSE }} run --rm claude bash

# Run a headless task in YOLO mode: just run "fix the lint errors"
run task:
    {{ COMPOSE }} run --rm claude claude --dangerously-skip-permissions -p "{{ task }}"

# Run the container security test suite
test:
    cd ../.. && UV_PROJECT_ENVIRONMENT=.venv uv run pytest .claude/container/tests/test_container_security.py -v
