# Ignore common large or irrelevant directories
.venv/
node_modules/
dist/
build/
.coverage/
.cache/
.pytest_cache/
__pycache__/
reports/
.docs_cache/

# Ignore local databases and binaries
*.db
*.sqlite3
*.sqlite
*.pyc
*.pyo
*.pyd
*.so
*.dylib
.DS_Store

# Ignore environment and secrets
.env
.env.*
*.key
*.pem

# Ignore generated assets
*.min.js
*.min.css
*.map
*.lock
uv.lock

# Ignore VCS and editor configs that shouldn’t be read into context
.git/
.github/
.vscode/
.idea/

# Ignore large artifacts and static outputs
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
*.pdf

# Project-specific: ignore example and temporary databases
example.db
simple_app.db
test.db
db.sqlite3

# Optional: ignore CI/CD outputs
coverage.xml
junit-*.xml
